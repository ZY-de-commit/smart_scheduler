# AI 配置
AI_PROVIDER=openai
OPENAI_API_KEY=sk-xxx
AI_MODEL=gpt-3.5-turbo
AI_BASE_URL=

# 服务器配置
PYTHON_PORT=5000
FLASK_ENV=development

# 音频配置
AUDIO_OUTPUT_DEVICE=
AUDIO_BLUETOOTH_DEVICE=
AUDIO_SPEECH_RATE=150
AUDIO_VOLUME=1.0

# 调度器配置
SCHEDULER_MAX_CONCURRENT_TASKS=5
SCHEDULER_TIMEZONE=Asia/Shanghai
