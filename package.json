{
  "name": "smart-scheduler",
  "version": "1.0.0",
  "description": "智能定时任务系统 - AI驱动的个性化信息聚合与语音播报",
  "main": "electron/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "cd electron/renderer && npm run dev",
    "dev:main": "npm run start",
    "build": "npm run build:renderer && electron-builder",
    "build:renderer": "cd electron/renderer && npm run build",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "keywords": [
    "electron",
    "scheduler",
    "ai",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "electron-store": "^8.1.0",
    "tree-kill": "^1.2.2",
    "uuid": "^9.0.1"
  },
  "build": {
    "appId": "com.smart-scheduler.app",
    "productName": "Smart Scheduler",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/main/**/*",
      "electron/renderer/dist/**/*",
      "python/**/*",
      "shared/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "python",
        "to": "python"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "shared/icons/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "shared/icons/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "shared/icons/icon.png"
    }
  }
}
